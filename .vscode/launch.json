{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Scoreboard (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/CTS_Scoreboard.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "subProcess": true,
            "env": {
                "SCOREBOARD_MODE": "development"
            }
        },
        {
            "name": "Scoreboard (Debug + Input File)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/CTS_Scoreboard.py",
            "python": "${workspaceFolder}/.venv/bin/python",
            "args": [
                "--in",
                "${input:inputFile}"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "subProcess": true,
            "env": {
                "SCOREBOARD_MODE": "development"
            }
        }
    ],
    "inputs": [
        {
            "id": "inputFile",
            "type": "promptString",
            "description": "Path to CTS input file to replay"
        }
    ]
}